<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!--
      Microphone: the daily capture is voice-first. On-device speech-to-text keeps the audio on
      the phone; only the resulting transcript text is ever sent to the AI layer.
      (Wired in Phase 1 — declared here so the capture surface has it from the start.)
    -->
    <uses-permission android:name="android.permission.RECORD_AUDIO" />

    <!-- Post the single daily reminder notification (Android 13+). Wired in Phase 1. -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <!-- Reschedule the daily reminder after a reboot. Wired in Phase 1. -->
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />

    <!-- Network: the AI categorizer / summary calls (Phase 2) and Drive backup (Phase 6). -->
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />

    <application
        android:name=".BragBuddyApp"
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:enableOnBackInvokedCallback="true"
        android:theme="@style/Theme.BragBuddy"
        tools:targetApi="34">

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:launchMode="singleTask"
            android:theme="@style/Theme.BragBuddy.Splash"
            android:windowSoftInputMode="adjustResize">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- The light, overlay-style capture surface. Translucent so the sheet floats over a scrim;
             launched from the Home mic FAB and the daily reminder. -->
        <activity
            android:name=".ui.capture.CaptureActivity"
            android:exported="false"
            android:launchMode="singleTop"
            android:excludeFromRecents="true"
            android:theme="@style/Theme.BragBuddy.Capture"
            android:windowSoftInputMode="adjustResize" />

    </application>

</manifest>
