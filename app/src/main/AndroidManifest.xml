<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!--
      Microphone: the daily capture is voice-first. Recorded audio is sent to Groq's cloud Whisper for
      transcription and is NOT retained afterwards — only the resulting transcript is kept. (An offline
      clip may wait briefly in private storage, then is deleted once transcribed — the Phase 7 queue.)
      On-device STT was removed in v0.9.0 (too inaccurate). Declared since Phase 1.
    -->
    <uses-permission android:name="android.permission.RECORD_AUDIO" />

    <!-- Post the single daily reminder notification (Android 13+). Wired in Phase 1. -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <!-- Reschedule the daily reminder after a reboot. Wired in Phase 1. -->
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />

    <!-- Fire the daily reminder at the exact chosen minute (was drifting on WorkManager's inexact
         periodic work). USE_EXACT_ALARM covers API 33+ (auto-granted); SCHEDULE_EXACT_ALARM covers
         API 31-32. Below 31 no permission is needed. Falls back to an inexact alarm if unavailable. -->
    <uses-permission android:name="android.permission.USE_EXACT_ALARM" />
    <uses-permission
        android:name="android.permission.SCHEDULE_EXACT_ALARM"
        android:maxSdkVersion="32" />

    <!-- Network: the AI categorizer / summary calls (Phase 2) and Drive backup (Phase 6).
         ACCESS_NETWORK_STATE also powers the Phase 7 offline queue (transcribe queued voice notes
         when the connection returns) and the calm offline copy. -->
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />

    <!-- Phase 7 · Reliable reminders: lets the guided screen show the direct system "Allow app to
         run in background?" dialog (ACTION_REQUEST_IGNORE_BATTERY_OPTIMIZATIONS) so the daily
         reminder survives aggressive OEM battery management (ColorOS etc.). Play-restricted — fine
         for a direct signed APK (same stance as USE_EXACT_ALARM above); revisit before any Play
         submission. -->
    <uses-permission android:name="android.permission.REQUEST_IGNORE_BATTERY_OPTIMIZATIONS" />

    <application
        android:name=".BragBuddyApp"
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:enableOnBackInvokedCallback="true"
        android:theme="@style/Theme.BragBuddy"
        tools:targetApi="34">

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:launchMode="singleTask"
            android:theme="@style/Theme.BragBuddy.Splash"
            android:windowSoftInputMode="adjustResize">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- The light, overlay-style capture surface. Translucent so the sheet floats over a scrim;
             launched from the Home mic FAB and the daily reminder. -->
        <activity
            android:name=".ui.capture.CaptureActivity"
            android:exported="false"
            android:launchMode="singleTop"
            android:excludeFromRecents="true"
            android:theme="@style/Theme.BragBuddy.Capture"
            android:windowSoftInputMode="adjustResize" />

        <!-- Daily reminder: fires the exact alarm and re-arms it (on fire, boot, and clock changes).
             Not exported — the alarm targets it explicitly; the boot/time broadcasts are protected. -->
        <receiver
            android:name=".reminder.ReminderReceiver"
            android:exported="false">
            <intent-filter>
                <action android:name="android.intent.action.BOOT_COMPLETED" />
                <action android:name="android.intent.action.MY_PACKAGE_REPLACED" />
                <action android:name="android.intent.action.TIME_SET" />
                <action android:name="android.intent.action.TIMEZONE_CHANGED" />
            </intent-filter>
        </receiver>

        <!-- FileProvider for the camera capture path (Phase A image scanning): hands the system
             camera a writable content:// Uri under cacheDir/capture_images. Authority uses
             ${applicationId} so it stays unique across the debug/release variants. -->
        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="${applicationId}.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/file_paths" />
        </provider>

    </application>

</manifest>
