<?xml version="1.0" encoding="utf-8"?>
<!--
   Android 11-and-below auto-backup rules (there is no device-transfer concept here — this attribute
   only governs cloud auto-backup). Privacy: nothing is auto-uploaded to the OS cloud backup; the
   user's record leaves the device only via BragBuddy's own opt-in Google Drive backup / manual export.
   So every domain is excluded here (matches the Android 12+ <cloud-backup> block). See PROGRESS.md.
-->
<full-backup-content>
    <exclude domain="file" path="." />
    <exclude domain="database" path="." />
    <exclude domain="sharedpref" path="." />
</full-backup-content>
