<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">

    <!-- Base app theme. Compose (MaterialTheme) owns all real styling; this XML theme only governs
         the window chrome and the pre-Compose frame so there is no flash on launch. The window
         background references @color/ab_bg, which flips automatically via values-night. -->
    <style name="Theme.BragBuddy" parent="android:Theme.Material.Light.NoActionBar">
        <item name="android:windowBackground">@color/ab_bg</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
        <item name="android:windowDrawsSystemBarBackgrounds">true</item>
        <item name="android:windowLightStatusBar">true</item>
        <item name="android:windowLayoutInDisplayCutoutMode" tools:targetApi="o_mr1">shortEdges</item>
    </style>

    <!-- Splash screen (androidx.core:core-splashscreen). Brand icon on the indigo background. -->
    <style name="Theme.BragBuddy.Splash" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">@color/ic_launcher_background</item>
        <item name="windowSplashScreenAnimatedIcon">@drawable/ic_launcher_foreground</item>
        <item name="postSplashScreenTheme">@style/Theme.BragBuddy</item>
    </style>

</resources>
